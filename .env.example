# Agent-Bridge environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# HTTP/WebSocket listen port
PORT=3000

# Shared API secret for all endpoints.
# Accepted as: Authorization: Bearer <key>  or  X-API-Key: <key>
# Leave unset in local dev to skip auth (never do this in production).
API_KEY=

# Allowed CORS origin
CORS_ORIGIN=http://localhost:3000

# Anthropic API key — enables real LLM responses in agent adapters.
# Without it, adapters return labelled stubs so the orchestrator still runs.
ANTHROPIC_API_KEY=
